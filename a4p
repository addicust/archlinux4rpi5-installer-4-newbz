a4pDev() {
    while true; do
        lsblk
        
        read -p "Enter the name of the storage device. NOTE, drives may not appear as you think they may due to things like SD to usb adapters, nvme to usv adapters: " input

		if [[ -b "/dev/$input" ]]; then
            SDDEV="/dev/$input"
        else
            echo "Invalid selection. Enter a valid storage device name."
            continue
        fi
        
        # Confirm the selected device
        echo "You have selected: $SDDEV"
        read -p "This device will be overwritten, confirm (y/n)? " confirm
        if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
            echo "Storage device confirmed: $SDDEV"
            break
        else
            echo "Try again."
        fi
    done
}

