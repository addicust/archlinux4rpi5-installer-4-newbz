echo "Set boot and root var names and find PARTUUID to fix /etc/fstab and /boot/cmdline.txt ...For SSD and usb users"

	mapfile -t PARTS < <(lsblk -nlo NAME "$SDDEV" | tail -n +2)  #first intelligently set var names from array
	SDPARTBOOT="/dev/${PARTS[0]}"
	SDPARTROOT="/dev/${PARTS[1]}"

	sudo blkid
	export BOOTPUUID="PARTUUID="$(sudo blkid -s PARTUUID -o value "$SDPARTBOOT") #this works   shellcheck says(warning): Declare and assign separately to avoid masking return values.
	export ROOTPUUID="PARTUUID="$(sudo blkid -s PARTUUID -o value "$SDPARTROOT")
	#echo $BOOTPUUID
	#echo $ROOTPUUID

echo "Backing up and updating /etc/fstab"
	sed -i.bac "s|/dev/mmcblk0p1|${BOOTPUUID}|g" ${SDMOUNT}/etc/fstab
	#echo "${ROOTPUUID}  /   vfat    defaults        0       0" >> ${SDMOUNT}/etc/fstab

echo "backup and update /boot/cmdline.txt"
	sed -i.bac "s|root=/dev/mmcblk0p2|root=${ROOTPUUID}|g" ${SDMOUNT}/boot/cmdline.txt #this works well


