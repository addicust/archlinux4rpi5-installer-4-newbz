a4pFSTAB() {
if [[ $FSTABFIXER == "y" || $FSTABFIXER == "Y" ]]; then
	echo "Backing up and updating /etc/fstab"

	sed -i.bac "s|/dev/mmcblk0p1|${BOOTPUUID}|g" ${SDMOUNT}/etc/fstab
#	echo "${BOOTPUUID}  /boot   vfat    defaults        0       0" >> ${SDMOUNT}/etc/fstab
	echo "${ROOTPUUID}  /   ext4    defaults        0       0" >> ${SDMOUNT}/etc/fstab

	echo "backup and update /boot/cmdline.txt"

	sed -i.bac "s|root=/dev/mmcblk0p2|root=${ROOTPUUID}|g" ${SDMOUNT}/boot/cmdline.txt #this works well
#	echo "root=${ROOTPUUID} rw rootwait console=serial0,115200 console=tty1 fsck.repair=yes splash quiet loglevel=3" > ${SDMOUNT}/boot/cmdline.txt


fi
}


a4pAB() {
if [[ $AFTERBOOT == "y" || $AFTERBOOt == "Y" ]]; then

cat << EOF > $SDMOUNT/root/afterBoot.txt
pacman-key --init
pacman-key --populate archlinuxarm

pacman -R linux-aarch64 uboot-raspberrypi
pacman -Syu --overwrite "/boot/*" linux-rpi
EOF
echo "afterboot file successfully installed at $SDMOUNT/root/afterBoot.txt"

fi
}

