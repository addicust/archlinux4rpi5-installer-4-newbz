a4pOSstore() {
local oldDLDIR="$DLDIR"
    while true; do
        read -p 'Choose a path to save installation files to (or press y for default): ' input

        # Expand tildes to full paths
        input="${input/#\~/$HOME}" #can this be fixed for root

        #input="${input/#\~/$HOME}" #something something $SUDO_USER

        # If user enters 'y', set to default path
        if [[ "$input" == "y" ]]; then
            DLDIR="$oldDLDIR"
        elif [[ -z "$input" || "$input" == "d" || "$input" == "default" ]]; then
            DLDIR="$oldDLDIR"
        else
            # Check if the input is a valid existing directory
            if [[ -d "$input" ]]; then
                DLDIR="$input"
            else
                echo "Invalid path. Enter a valid existing directory path."
                continue
            fi
        fi
        
        # Confirm the selected path
        echo "You have selected: $DLDIR"
        read -p 'Confirm this path (y/n)? ' confirm
        if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
