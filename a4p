a4pChoose() {
    while true; do
        read -p "Do you want to (d)ownload files or (s)elect existing files? (Enter d or s): " choice

        if [[ "$choice" == "d" || "$choice" == "D" ]]; then
            # Prompt for the download URL
		read -p "Enter the URL to download from (default is $DISTURL)" url
		url="${url:-$DISTURL}"  # set to DISTURL if no input is provided
            echo "You have selected download URL: $DISTURL"

            # Confirm the download URL
            read -p "Confirm this URL (y/n)? " confirm_url
            if [[ "$confirm_url" == "y" || "$confirm_url" == "Y" ]]; then
                echo "Download URL confirmed: $DISTURL"
                LOCALFILES=n

