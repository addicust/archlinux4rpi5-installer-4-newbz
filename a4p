fstabFixer() {  #TEST SO SEE IF WE CAN RUN THIS FOR SD CARDS WITH NO ILL EFECTS, in which case we will make it auto run every installation

while true; do

        read -p "If the device is not an SD card, /etc/fstab needs to be modified, press y to continue to fix fstab." input

        if [[ "$input" == "y" ]]; then
			# Store all partitions into an array (skipping the first entry which is the disk itself)
			mapfile -t PARTS < <(lsblk -nlo NAME "$SDDEV" | tail -n +2)
			SDPARTBOOT="/dev/${PARTS[0]}"
			SDPARTROOT="/dev/${PARTS[1]}"

		else
			break
		fi
done
}



