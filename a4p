# Function to allow user to redo previous steps or continue
a4pMenu() {
    while true; do
        echo "Y for default options or select any steps below to reconfigure."
        echo '1) Select storage device'
        echo '2) Select download URL or existing directory path'
        echo '4) Continue (or type y)'

        read -p "Select an option (1-4 or y): " option

        # Check if user typed 'y' for continue
        if [[ $option == "y" || $option == "Y"  ]]; then
            echo "Proceeding with the selected options..."
            return
        fi

        case $option in
            1)
                a4pDev
                ;;
            2)
                a4pChoose
                ;;
	    3)
		a4pAfter
		;;
            4)
                return
                ;;
            *)
                echo "Invalid option. Please select a valid number or y to continue."
                ;;
        esac
    done
}


