##make partition helper for dumeez
a4pPart() {
echo "format and partition $SDDEV"
sudo sfdisk --quiet --wipe always "$SDDEV" << EOF
,512M,0c,
,,,
EOF
}


a4pPartVar() {
#WE NEED TO FIGURE OUT SDPARTBOOT AND ROOT HERE
# Store all partitions into an array (skipping the first entry which is the disk itself)
mapfile -t PARTS < <(lsblk -nlo NAME "$SDDEV" | tail -n +2)
SDPARTBOOT="/dev/${PARTS[0]}"
SDPARTROOT="/dev/${PARTS[1]}"
echo "Boot Partition: $SDPARTBOOT"
echo "Root Partition: $SDPARTROOT"
}


a4pFS() {
	echo "create filesystem"
sudo mkfs.vfat -F 32 "$SDPARTBOOT"
sudo mkfs.ext4 -E lazy_itable_init=0,lazy_journal_init=0 -F "$SDPARTROOT"
}


a4pMNT() {
echo "creating mount at $SDMOUNT"
mkdir -p "$SDMOUNT"
mount "$SDPARTROOT" "$SDMOUNT"
mkdir -p "${SDMOUNT}"/boot
mount "$SDPARTBOOT" ${SDMOUNT}/boot
}


a4pWAlarm() {
echo "write image to disk, this will take a while."
bsdtar -xvpf "${DLDIR}"/"${DISTURL##*/}" -C "$SDMOUNT"
#bsdtar -xvpf ${DLDIR}/ArchLinuxARM-rpi-aarch64-latest.tar.gz -C $SDMOUNT

echo "remove arch bootloader"
rm -rf ${SDMOUNT:?}/boot/* || { echo "failed to remove arch bootloader, returning to menu"; a4pMenu; }

}


