a4pDev() {
    while true; do
        lsblk
        
        read -p "Enter the name of the storage device (or press y for default): " input

        if [[ "$input" == "y" ]]; then
            break
        elif [[ -b "/dev/$input" ]]; then
            SDDEV="/dev/$input"
            #SDPARTBOOT=${SDDEV}1
            #SDPARTROOT=${SDDEV}2 #wait to set these var until fstab helper get correct input from user
        else
            echo "Invalid selection. Enter a valid storage device name."
            continue
        fi
        
        # Confirm the selected device
        echo "You have selected: $SDDEV"
        read -p "This device will be overwritten, confirm (y/n)? " confirm
        if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
            echo "Storage device confirmed: $SDDEV"
            break
        else
            echo "Try again."
        fi
    done
}

